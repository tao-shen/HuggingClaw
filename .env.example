# HuggingClaw 环境变量示例
# 复制为 .env 后填写，或在 HF Space 的 Settings -> Repository secrets 中配置

# ========== 持久化（必填）==========
# 具有写权限的 Hugging Face Access Token
HF_TOKEN=
# 用于备份的 Dataset 仓库，格式: username/dataset-name
OPENCLAW_DATASET_REPO=

# ========== Telegram 机器人（可选）==========
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_NAME=
# TELEGRAM_ALLOW_USER=

# ========== 可选 ==========
# 同步间隔（秒），默认 120
# SYNC_INTERVAL=120
# 是否启用辅助服务，默认 false
# ENABLE_AUX_SERVICES=false
